---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TreatmentsLanding from '../../components/TreatmentsLanding.astro';
import { treatments, getTreatmentUrl } from '../../lib/treatments';
import { absoluteUrl, getBreadcrumbSchema } from '../../lib/site';

const itemListSchema = {
  '@type': 'ItemList',
  name: 'Tratamientos de masaje en Tarragona',
  itemListElement: treatments.map((treatment, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: treatment.titulo,
    url: absoluteUrl(getTreatmentUrl(treatment.slug)),
  })),
};

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Inicio', url: absoluteUrl('/') },
  { name: 'Tratamientos', url: absoluteUrl('/') },
]);
---

<BaseLayout
  title="Tratamientos de Masaje en Tarragona | Kadō Masajes"
  description="Explora los tratamientos de Kadō Masajes en Tarragona: masaje californiano, relajante, deportivo, deep tissue, facial y reflexología podal."
  image="/portada3-1800.webp"
  robots="noindex,follow"
  canonicalPath="/"
  structuredData={[breadcrumbSchema, itemListSchema]}
>
  <TreatmentsLanding h1="Tratamientos de masaje en Tarragona | Kadō Masajes" />
</BaseLayout>
